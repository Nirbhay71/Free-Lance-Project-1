# Dependencies
node_modules/
/jspm_packages/
/web_modules/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Multer / Local Upload Temporary Files
/public/temp/*
!/public/temp/.gitkeep

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#testing)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp compilation directory (https://code.google.com/p/node-gyp/)
build/

# MarkBind cache directory (https://markbind.org/)
.markbind/

# Dependency directories (ycmd)
third_party/

# IDEs and editors
.idea/
.vscode/
*.suo
